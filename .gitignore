# Ignore local Terraform configuration directories (plugins, cache, modules)
terraform/.terraform/

# Ignore local state files and backup copies
terraform/*.tfstate
terraform/*.tfstate.*

# Ignore variables and secrets files containing sensitive data
terraform/*.tfvars
terraform/*.tfvars.json

# Ignore custom override files
terraform/*_override.tf
terraform/*_override.tf.json

# Ignore local CLI configuration files
terraform/.terraformrc
terraform/terraform.rc

# Ignore log files
terraform/*.log
